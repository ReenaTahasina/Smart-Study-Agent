# ─────────────────────────────────────────────────────────────────────────────
# Smart Study Agent — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# IBM watsonx.ai endpoint (region-specific)
WATSONX_URL=https://<region>.ml.cloud.ibm.com/ml/v1/text/chat?version=2023-05-29

# Your IBM Cloud watsonx project ID
PROJECT_ID=your-project-id-here

# IBM Granite model ID
MODEL_ID=ibm/granite-4-h-small

# IBM Cloud API key (create at https://cloud.ibm.com/iam/apikeys)
IBM_API_KEY=your-ibm-cloud-api-key-here

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here
